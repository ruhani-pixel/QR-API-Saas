// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}




model Device {
  id             String   @id @default(cuid())
  name           String
  number         String?
  sessionId      String   @unique
  status         String   @default("offline") // online | offline | connecting
  currentQR      String?
  ownerNumber    String?
  aiEnabled           Boolean  @default(false)
  aiInstructions      String?
  aiReplyNewUsers     Boolean  @default(true)
  aiReplyExistingUsers Boolean @default(true)
  createdAt           DateTime @default(now())
  updatedAt      DateTime @updatedAt
  messages       MessageLog[]
  chatMessages   Message[]
  contacts       Contact[]
}

model Campaign {
  id              String        @id @default(cuid())
  name            String
  message         String?
  mediaPath       String?
  selectedDevices String?       // JSON array of sessionIds
  status          String        @default("pending") // pending | active | paused | completed | stopped
  totalSent       Int           @default(0)
  totalFailed      Int           @default(0)
  totalNumbers    Int           @default(0)
  safetyConfig    String?       // JSON: { minDelay, maxDelay, burstLimit, restPeriod }
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  logs            MessageLog[]
  recipients      CampaignRecipient[]
}

model CampaignRecipient {
  id               String    @id @default(cuid())
  campaignId       String
  number           String
  message          String?   // Personalized message
  scheduledAt      DateTime? // Per-message scheduled time
  nodeId           String?   // Force specific SIM/Node
  status           String    @default("pending") // pending | sent | failed
  campaign         Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model MessageLog {
  id               String    @id @default(cuid())
  simId            String
  campaignId       String?
  recipientNumber  String
  recipientName    String    @default("")
  status           String    // sent | failed | pending
  failReason       String?
  sentAt           DateTime  @default(now())
  campaign         Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  device           Device?   @relation(fields: [simId], references: [sessionId], onDelete: Cascade)
}

model Message {
  id               String    @id @default(cuid())
  whatsappId       String?   @unique
  sessionId        String
  remoteJid        String
  pushName         String?
  content          String
  type             String    @default("text") // text | image | video | document
  direction        String    // inbound | outbound
  status           String    @default("delivered") // pending | sent | delivered | read | failed
  mediaPath        String?   // For images/videos/docs
  fileName         String?   // Original filename
  timestamp        DateTime  @default(now())
  messageTimestamp Int?      // Original WhatsApp timestamp
  
  device           Device    @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
}

model Contact {
  id               String    @id @default(cuid())
  sessionId        String
  remoteJid        String    @unique
  name             String?
  pushName         String?
  profilePic       String?
  aiEnabled        Boolean   @default(true)
  updatedAt        DateTime  @updatedAt

  device           Device    @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@unique([sessionId, remoteJid])
}
